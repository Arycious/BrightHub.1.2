{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "./dist-server",
    "rootDir": "./src",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/server.ts", "src/lib/**/*.ts", "src/types/**/*.ts"],
  "exclude": ["node_modules", "src/lib/store.ts", "src/lib/i18n.ts", "src/hooks/**", "src/components/**"]
}
